# bio-manim-lab environment
# OPENAI_API_KEY is OPTIONAL. Without it, the pipeline falls back to golden
# cached outputs for known topics (currently: ATP synthase).

OPENAI_API_KEY=

# Optional knobs
BIOMANIM_LLM_PROVIDER=openai         # openai | golden
BIOMANIM_LLM_MODEL=gpt-4o-mini
BIOMANIM_LLM_TIMEOUT=120
BIOMANIM_LOG_LEVEL=INFO

# Optional external tool paths (only used if --quant or import-graphify)
MATHCODE_BIN=
GRAPHIFY_BIN=
